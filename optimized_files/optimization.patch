+                        continue
+                    if not isinstance(data, dict):
+                        continue
+                    ts = data.get("timestamp")
+                    if not isinstance(ts, (int, float)):
+                        yield data
+                        continue
+                    if ts < cutoff_ms:
+                        continue
+                    if end_ms is not None and ts > end_ms:
+                        break
+                    yield data
+        except FileNotFoundError:
+            return
